# Apple Developer 证书配置
# 用于代码签名和公证的环境变量

# Apple ID (用于公证)
APPLE_ID=your-apple-id@example.com

# Apple ID 专用密码 (App-specific password)
APPLE_ID_PASS=your-app-specific-password

# Apple Team ID
APPLE_TEAM_ID=YOUR_TEAM_ID

# 代码签名身份 (可选，如果不设置会自动查找)
# CSC_NAME="Developer ID Application: YOUR_NAME (YOUR_TEAM_ID)"

# 是否在 CI 环境中运行
CI=false